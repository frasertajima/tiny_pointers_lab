   000116                    88  PLACED-YES       VALUE 'Y'.                                      |                                  
   000117                01  WS-FOUND             PIC X VALUE 'N'.                                |                                  
   000118                    88  FOUND-YES        VALUE 'Y'.                                      |                                  
   000119                01  WS-STOP              PIC X VALUE 'N'.                                |                                  
   000120                    88  STOP-YES         VALUE 'Y'.                                      |                                  
   000121                01  WS-RESULT-NAME       PIC X(20).                                      |                                  
   000122                01  WS-IDX-Z             PIC 9(6).                                       |                                  
   000123                01  WS-SEED              PIC 9(18) VALUE 12345.                          |                                  
   000124                01  WS-CIDX              PIC 9(9).                                       |                                  
   000125                                                                                         |                                  
   000126               *--- statistics -------------------------------------------------         |                                  
   000127                01  WS-CUST-COUNT        PIC 9(6)  VALUE 0.                              |                                  
   000128                01  WS-PLACED-BUCKET     PIC 9(6)  VALUE 0.                              |                                  
   000129                01  WS-PLACED-OVF        PIC 9(6)  VALUE 0.                              |                                  
   000130                01  WS-HARD-FAIL         PIC 9(6)  VALUE 0.                              |                                  
   000131                01  WS-MAX-OCC           PIC 9(2)  VALUE 0.                              |                                  
   000132                01  WS-ORDER-COUNT       PIC 9(8)  VALUE 0.                              |                                  
   000133                01  WS-MATCH-COUNT       PIC 9(8)  VALUE 0.                              |                                  
   000134                                                                                         |                                  
   000135               *--- derived figures for the report -----------------------------         |                                  
   000136                01  WS-PRIM-CAP          PIC 9(7).                                       |                                  
   000137                01  WS-LOAD-PCT          PIC ZZ9.99.                                     |                                  
   000138                01  WS-OVF-PCT           PIC ZZ9.99.                                     |                                  
   000139                01  WS-TINY-BITS-TOT     PIC 9(9).                                       |                                  
   000140                01  WS-TINY-BYTES        PIC 9(7).                                       |                                  
   000141                01  WS-FULL-BYTES        PIC 9(7).                                       |                                  
   000142                01  WS-RATIO             PIC ZZ9.99.                                     |                                  
   000143                01  WS-BLEND-BITS        PIC Z9.99.                                      |                                  
   000144                01  WS-MATCH-PCT         PIC ZZ9.99.                                     |                                  
   000145                01  WS-SAMPLE            PIC 9(2) VALUE 0.                               |                                  
   000146                                                                                         |                                  
   000147               *--- edited fields for display ----------------------------------         |                                  
   000148                01  WS-ED6               PIC ZZZ,ZZ9.                                    |                                  
   000149                01  WS-ED7               PIC Z,ZZZ,ZZ9.                                  |                                  
   000150                01  WS-ED2               PIC Z9.                                         |                                  
   000151                                                                                         |                                  
   000152                PROCEDURE DIVISION.                                                      |                                  
   000153                                                                                         |                                  
   000154                0000-MAIN SECTION.                                                       |                                  
   000155                    PERFORM 1000-GEN-DATA                                                |164                               
   000156                    PERFORM 2000-BUILD-TABLE                                             |193                               
   000157                    PERFORM 3000-JOIN                                                    |262                               
   000158                    PERFORM 9000-REPORT                                                  |330                               
   000159                    STOP RUN.                                                            |                                  
   000160                                                                                         |                                  
   000161               ******************************************************************        |                                  
   000162               *  1000 -- generate the two relational tables as flat files               |                                  
   000163               ******************************************************************        |                                  
   000164                1000-GEN-DATA SECTION.                                                   |                                  
   000165                1000-GEN.                                                                |                                  
   000166                    OPEN OUTPUT CUSTOMER-FILE                                            |48                                
   000167                    PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > N-CUST                 |108 108 77                        
   000168      1                 COMPUTE CR-ID = CUST-BASE + WS-I                                 |50 79 108                         
   000169      1                 MOVE WS-I TO WS-IDX-Z                                            |108 122                           
   000170      1                 MOVE SPACES TO CR-NAME                                           |IMP 51                            
   000171      1                 STRING 'CUSTOMER-' DELIMITED BY SIZE                             |                                  
1PP 5737-L11 IBM COBOL for Linux                     1.2.0      TINYJOIN  Date 06/13/2026  Time 19:50:20   Page     5               
   LineID  PL SL  ----+-*A-1-B--+----2----+----3----+----4----+----5----+----6----+----7-|--+----8 Map and Cross Reference           
0  000172      1                        WS-IDX-Z    DELIMITED BY SIZE                             |122                               
   000173      1                     INTO CR-NAME                                                 |51                                
   000174      1                 WRITE CUST-REC                                                   |49                                
   000175                    END-PERFORM                                                          |                                  
   000176                    CLOSE CUSTOMER-FILE                                                  |48                                
   000177                                                                                         |                                  
   000178               *    orders reference a random existing customer (Park-Miller LCG)        |                                  
   000179                    OPEN OUTPUT ORDERS-FILE                                              |53                                
   000180                    PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > N-ORDER                |108 108 78                        
   000181      1                 COMPUTE WS-SEED = FUNCTION MOD(WS-SEED * 16807, 2147483647)      |123 IFN 123                       
   000182      1                 COMPUTE WS-CIDX = FUNCTION MOD(WS-SEED, N-CUST) + 1              |124 IFN 123 77                    
   000183      1                 COMPUTE OR-ID  = 10000000 + WS-I                                 |55 108                            
   000184      1                 COMPUTE OR-CID = CUST-BASE + WS-CIDX                             |56 79 124                         
   000185      1                 COMPUTE OR-AMT = FUNCTION MOD(WS-SEED, 100000000)                |57 IFN 123                        
   000186      1                 WRITE ORD-REC                                                    |54                                
   000187                    END-PERFORM                                                          |                                  
   000188                    CLOSE ORDERS-FILE.                                                   |53                                
   000189                                                                                         |                                  
   000190               ******************************************************************        |                                  
   000191               *  2000 -- build the dereference table from CUSTOMER.DAT                  |                                  
   000192               ******************************************************************        |                                  
   000193                2000-BUILD-TABLE SECTION.                                                |                                  
   000194                2000-BUILD.                                                              |                                  
   000195               *    clear the arenas (0 key = empty slot)                                |                                  
   000196                    PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > NBKT                   |108 108 74                        
   000197      1                 MOVE 0 TO B-OCC(WS-I)                                            |108 88                            
   000198      1                 PERFORM VARYING WS-J FROM 1 BY 1 UNTIL WS-J > BSLOTS             |109 109 75                        
   000199      2                     MOVE 0 TO P-KEY(WS-I, WS-J)                                  |108 109 85                        
   000200      1                 END-PERFORM                                                      |                                  
   000201                    END-PERFORM                                                          |                                  
   000202                    PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > OVF-CAP                |108 108 76                        
   000203      1                 MOVE 0 TO O-KEY(WS-I)                                            |108 93                            
   000204                    END-PERFORM                                                          |                                  
   000205                                                                                         |                                  
   000206                    OPEN INPUT CUSTOMER-FILE                                             |48                                
   000207                    MOVE 'N' TO WS-EOF                                                   |106                               
   000208                    PERFORM UNTIL EOF-YES                                                |107                               
   000209      1                 READ CUSTOMER-FILE                                               |48                                
   000210      2                     AT END SET EOF-YES TO TRUE                                   |107                               
   000211      1                     NOT AT END                                                   |                                  
   000212      2                         ADD 1 TO WS-CUST-COUNT                                   |127                               
   000213      2                         PERFORM 2100-INSERT                                      |219                               
   000214      1                 END-READ                                                         |                                  
   000215                    END-PERFORM                                                          |                                  
   000216                    CLOSE CUSTOMER-FILE.                                                 |48                                
   000217                                                                                         |                                  
   000218               *    insert current CUST-REC : bucket first, then overflow backup         |                                  
   000219                2100-INSERT.                                                             |                                  
   000220                    COMPUTE WS-HV  = CR-ID * 2654435761                                  |114 50                            
   000221                    COMPUTE WS-BKT = FUNCTION MOD(WS-HV, NBKT) + 1                       |111 IFN 114 74                    
   000222                    MOVE 'N' TO WS-PLACED                                                |115                               
   000223                    PERFORM VARYING WS-J FROM 1 BY 1                                     |109                               
   000224                            UNTIL WS-J > BSLOTS OR PLACED-YES                            |109 75 116                        
   000225      1                 IF P-KEY(WS-BKT, WS-J) = 0                                       |111 109 85                        
   000226      2                     MOVE CR-ID   TO P-KEY(WS-BKT, WS-J)                          |50 111 109 85                     
   000227      2                     MOVE CR-NAME TO P-NAME(WS-BKT, WS-J)                         |51 111 109 86                     
   000228      2                     ADD 1 TO B-OCC(WS-BKT)                                       |111 88                            
1PP 5737-L11 IBM COBOL for Linux                     1.2.0      TINYJOIN  Date 06/13/2026  Time 19:50:20   Page     6               
   LineID  PL SL  ----+-*A-1-B--+----2----+----3----+----4----+----5----+----6----+----7-|--+----8 Map and Cross Reference           
0  000229      2                     ADD 1 TO WS-PLACED-BUCKET                                    |128                               
   000230      2                     SET PLACED-YES TO TRUE                                       |116                               
   000231      1                 END-IF                                                           |                                  
   000232                    END-PERFORM                                                          |                                  
   000233                    IF B-OCC(WS-BKT) > WS-MAX-OCC                                        |111 88 131                        
   000234      1                 MOVE B-OCC(WS-BKT) TO WS-MAX-OCC                                 |111 88 131                        
   000235                    END-IF                                                               |                                  
   000236                    IF NOT PLACED-YES                                                    |116                               
   000237      1                 PERFORM 2200-INSERT-OVF                                          |241                               
   000238                    END-IF.                                                              |                                  
   000239                                                                                         |                                  
   000240               *    backup table : linear probe from a second hash of the key            |                                  
   000241                2200-INSERT-OVF.                                                         |                                  
   000242                    COMPUTE WS-OH = FUNCTION MOD(CR-ID * 40503, OVF-CAP)                 |112 IFN 50 76                     
   000243                    MOVE 'N' TO WS-PLACED                                                |115                               
   000244                    PERFORM VARYING WS-I FROM 0 BY 1                                     |108                               
   000245                            UNTIL WS-I >= OVF-CAP OR PLACED-YES                          |108 76 116                        
   000246      1                 COMPUTE WS-STMP = WS-OH + WS-I                                   |113 112 108                       
   000247      1                 COMPUTE WS-S = FUNCTION MOD(WS-STMP, OVF-CAP) + 1                |110 IFN 113 76                    
   000248      1                 IF O-KEY(WS-S) = 0                                               |110 93                            
   000249      2                     MOVE CR-ID   TO O-KEY(WS-S)                                  |50 110 93                         
   000250      2                     MOVE CR-NAME TO O-NAME(WS-S)                                 |51 110 94                         
   000251      2                     ADD 1 TO WS-PLACED-OVF                                       |129                               
   000252      2                     SET PLACED-YES TO TRUE                                       |116                               
   000253      1                 END-IF                                                           |                                  
   000254                    END-PERFORM                                                          |                                  
   000255                    IF NOT PLACED-YES                                                    |116                               
   000256      1                 ADD 1 TO WS-HARD-FAIL                                            |130                               
   000257                    END-IF.                                                              |                                  
   000258                                                                                         |                                  
   000259               ******************************************************************        |                                  
   000260               *  3000 -- probe with ORDERS.DAT and emit the joined rows                 |                                  
   000261               ******************************************************************        |                                  
   000262                3000-JOIN SECTION.                                                       |                                  
   000263                3000-DO-JOIN.                                                            |                                  
   000264                    OPEN INPUT ORDERS-FILE                                               |53                                
   000265                    OPEN OUTPUT JOINED-FILE                                              |59                                
   000266                    MOVE 'N' TO WS-EOF                                                   |106                               
   000267                    PERFORM UNTIL EOF-YES                                                |107                               
   000268      1                 READ ORDERS-FILE                                                 |53                                
   000269      2                     AT END SET EOF-YES TO TRUE                                   |107                               
   000270      1                     NOT AT END                                                   |                                  
   000271      2                         ADD 1 TO WS-ORDER-COUNT                                  |132                               
   000272      2                         PERFORM 3100-PROBE                                       |290                               
   000273      2                         IF FOUND-YES                                             |118                               
   000274      3                             ADD 1 TO WS-MATCH-COUNT                              |133                               
   000275      3                             MOVE OR-ID         TO JN-OID                         |55 61                             
   000276      3                             MOVE OR-CID        TO JN-CID                         |56 63                             
   000277      3                             MOVE WS-RESULT-NAME TO JN-NAME                       |121 65                            
   000278      3                             MOVE OR-AMT        TO JN-AMT                         |57 67                             
   000279      3                             MOVE SPACES TO JN-REC(9:1) JN-REC(16:1)              |IMP                               
   000280      3                                            JN-REC(37:1)                          |60 60 60                          
   000281      3                             WRITE JN-REC                                         |60                                
   000282      3                             PERFORM 3200-SAMPLE                                  |320                               
   000283      2                         END-IF                                                   |                                  
   000284      1                 END-READ                                                         |                                  
   000285                    END-PERFORM                                                          |                                  
1PP 5737-L11 IBM COBOL for Linux                     1.2.0      TINYJOIN  Date 06/13/2026  Time 19:50:20   Page     7               
   LineID  PL SL  ----+-*A-1-B--+----2----+----3----+----4----+----5----+----6----+----7-|--+----8 Map and Cross Reference           
0  000286                    CLOSE ORDERS-FILE                                                    |53                                
   000287                    CLOSE JOINED-FILE.                                                   |59                                
   000288                                                                                         |                                  
   000289               *    DEREFERENCE : recompute the bucket from the key, scan <= B           |                                  
   000290                3100-PROBE.                                                              |                                  
   000291                    COMPUTE WS-HV  = OR-CID * 2654435761                                 |114 56                            
   000292                    COMPUTE WS-BKT = FUNCTION MOD(WS-HV, NBKT) + 1                       |111 IFN 114 74                    
   000293                    MOVE 'N' TO WS-FOUND                                                 |117                               
   000294                    PERFORM VARYING WS-J FROM 1 BY 1                                     |109                               
   000295                            UNTIL WS-J > BSLOTS OR FOUND-YES                             |109 75 118                        
   000296      1                 IF P-KEY(WS-BKT, WS-J) = OR-CID                                  |111 109 85 56                     
   000297      2                     MOVE P-NAME(WS-BKT, WS-J) TO WS-RESULT-NAME                  |111 109 86 121                    
   000298      2                     SET FOUND-YES TO TRUE                                        |118                               
   000299      1                 END-IF                                                           |                                  
   000300                    END-PERFORM                                                          |                                  
   000301                    IF NOT FOUND-YES                                                     |118                               
   000302      1                 COMPUTE WS-OH = FUNCTION MOD(OR-CID * 40503, OVF-CAP)            |112 IFN 56 76                     
   000303      1                 MOVE 'N' TO WS-STOP                                              |119                               
   000304      1                 PERFORM VARYING WS-I FROM 0 BY 1                                 |108                               
   000305      1                         UNTIL WS-I >= OVF-CAP OR FOUND-YES OR STOP-YES           |108 76 118 120                    
   000306      2                     COMPUTE WS-STMP = WS-OH + WS-I                               |113 112 108                       
   000307      2                     COMPUTE WS-S = FUNCTION MOD(WS-STMP, OVF-CAP) + 1            |110 IFN 113 76                    
   000308      2                     IF O-KEY(WS-S) = OR-CID                                      |110 93 56                         
   000309      3                         MOVE O-NAME(WS-S) TO WS-RESULT-NAME                      |110 94 121                        
   000310      3                         SET FOUND-YES TO TRUE                                    |118                               
   000311      2                     ELSE                                                         |                                  
   000312      3                         IF O-KEY(WS-S) = 0                                       |110 93                            
   000313      4                             SET STOP-YES TO TRUE                                 |120                               
   000314      3                         END-IF                                                   |                                  
   000315      2                     END-IF                                                       |                                  
   000316      1                 END-PERFORM                                                      |                                  
   000317                    END-IF.                                                              |                                  
   000318                                                                                         |                                  
   000319               *    keep the first few matches for an on-screen sample                   |                                  
   000320                3200-SAMPLE.                                                             |                                  
   000321                    IF WS-SAMPLE < 5                                                     |145                               
   000322      1                 ADD 1 TO WS-SAMPLE                                               |145                               
   000323      1                 DISPLAY '   order ' OR-ID ' -> cust ' OR-CID                     |55 56                             
   000324      1                         ' = ' WS-RESULT-NAME                                     |121                               
   000325                    END-IF.                                                              |                                  
   000326                                                                                         |                                  
   000327               ******************************************************************        |                                  
   000328               *  9000 -- the report : density + handle width                            |                                  
   000329               ******************************************************************        |                                  
   000330                9000-REPORT SECTION.                                                     |                                  
   000331                9000-RPT.                                                                |                                  
   000332                    COMPUTE WS-PRIM-CAP = NBKT * BSLOTS                                  |136 74 75                         
   000333                    COMPUTE WS-LOAD-PCT = 100.0 * WS-PLACED-BUCKET / WS-PRIM-CAP         |137 128 136                       
   000334                    COMPUTE WS-OVF-PCT  = 100.0 * WS-PLACED-OVF / OVF-CAP                |138 129 76                        
   000335                    COMPUTE WS-MATCH-PCT =                                               |144                               
   000336                            100.0 * WS-MATCH-COUNT / WS-ORDER-COUNT                      |133 132                           
   000337                                                                                         |                                  
   000338               *    handle width: in-bucket = 3 bits (log2 8), overflow = 10 bits        |                                  
   000339               *    (log2 768).  Compare to a 4-byte (32-bit) record pointer/RRN.        |                                  
   000340                    COMPUTE WS-TINY-BITS-TOT =                                           |139                               
   000341                            WS-PLACED-BUCKET * 3 + WS-PLACED-OVF * 10                    |128 129                           
   000342                    COMPUTE WS-TINY-BYTES = WS-TINY-BITS-TOT / 8                         |140 139                           
