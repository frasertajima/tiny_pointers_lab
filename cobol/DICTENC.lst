   000283               *  3000 -- decode ENCODED.DAT and verify against COLUMN.DAT               |                                  
   000284               ******************************************************************        |                                  
   000285                3000-DECODE-VERIFY SECTION.                                              |                                  
1PP 5737-L11 IBM COBOL for Linux                     1.2.0      DICTENC   Date 06/13/2026  Time 20:07:55   Page     7               
   LineID  PL SL  ----+-*A-1-B--+----2----+----3----+----4----+----5----+----6----+----7-|--+----8 Map and Cross Reference           
0  000286                3000-DEC.                                                                |                                  
   000287                    OPEN INPUT COLUMN-FILE                                               |44                                
   000288                    OPEN INPUT ENCODED-FILE                                              |48                                
   000289                    MOVE 'N' TO WS-EOF                                                   |94                                
   000290                    PERFORM UNTIL EOF-YES                                                |95                                
   000291      1                 READ COLUMN-FILE                                                 |44                                
   000292      2                     AT END SET EOF-YES TO TRUE                                   |95                                
   000293      1                     NOT AT END                                                   |                                  
   000294      2                         READ ENCODED-FILE                                        |48                                
   000295      3                             AT END SET EOF-YES TO TRUE                           |95                                
   000296      2                             NOT AT END                                           |                                  
   000297      3                                 ADD 1 TO WS-DEC-COUNT                            |120                               
   000298      3                                 IF CT-STR(EN-CODE) NOT = COL-STR                 |50 81 46                          
   000299      4                                     ADD 1 TO WS-MISMATCH                         |121                               
   000300      3                                 END-IF                                           |                                  
   000301      3                                 PERFORM 3100-SAMPLE                              |308                               
   000302      2                         END-READ                                                 |                                  
   000303      1                 END-READ                                                         |                                  
   000304                    END-PERFORM                                                          |                                  
   000305                    CLOSE COLUMN-FILE                                                    |44                                
   000306                    CLOSE ENCODED-FILE.                                                  |48                                
   000307                                                                                         |                                  
   000308                3100-SAMPLE.                                                             |                                  
   000309                    IF WS-SAMPLE < 5                                                     |122                               
   000310      1                 ADD 1 TO WS-SAMPLE                                               |122                               
   000311      1                 DISPLAY '   "' COL-STR '" -> code ' EN-CODE                      |46 50                             
   000312                    END-IF.                                                              |                                  
   000313                                                                                         |                                  
   000314               ******************************************************************        |                                  
   000315               *  9000 -- the report : density, handle width, compression                |                                  
   000316               ******************************************************************        |                                  
   000317                9000-REPORT SECTION.                                                     |                                  
   000318                9000-RPT.                                                                |                                  
   000319                    COMPUTE WS-PRIM-CAP = NBKT * BSLOTS                                  |125 55 56                         
   000320                    COMPUTE WS-LOAD-PCT =                                                |126                               
   000321                            100.0 * WS-PLACED-BUCKET / WS-PRIM-CAP                       |115 125                           
   000322                                                                                         |                                  
   000323               *    code width in bits = smallest c with 2^c >= distinct values          |                                  
   000324                    MOVE 1 TO WS-CODEBITS                                                |127                               
   000325                    MOVE 2 TO WS-POW                                                     |128                               
   000326                    PERFORM UNTIL WS-POW >= WS-NEXT-CODE                                 |128 112                           
   000327      1                 COMPUTE WS-POW = WS-POW * 2                                      |128 128                           
   000328      1                 ADD 1 TO WS-CODEBITS                                             |127                               
   000329                    END-PERFORM                                                          |                                  
   000330                                                                                         |                                  
   000331                    COMPUTE WS-RAW-BYTES  = WS-ROW-COUNT * STR-BYTES                     |129 119 60                        
   000332                    COMPUTE WS-ENC-BYTES  =                                              |130                               
   000333                            (WS-ROW-COUNT * WS-CODEBITS + 7) / 8                         |119 127                           
   000334                    COMPUTE WS-DICT-BYTES = WS-NEXT-CODE * STR-BYTES                     |131 112 60                        
   000335                    COMPUTE WS-TOTAL-BYTES = WS-ENC-BYTES + WS-DICT-BYTES                |132 130 131                       
   000336                    COMPUTE WS-RATIO ROUNDED =                                           |133                               
   000337                            WS-RAW-BYTES / WS-TOTAL-BYTES                                |129 132                           
   000338                                                                                         |                                  
   000339                    DISPLAY ' '                                                          |                                  
   000340                    DISPLAY '==============================================='            |                                  
